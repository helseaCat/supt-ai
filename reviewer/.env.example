# GitHub App credentials (required)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Webhook signature verification (required for intake Lambda)
WEBHOOK_SECRET=

# xAI API key for Grok LLM calls (required)
XAI_API_KEY=

# Discord webhook URL for review notifications (optional)
DISCORD_WEBHOOK_URL=

# AWS Secrets Manager ARN (set by CDK in Lambda, override for local dev)
SECRETS_ARN=

# Override review timeout in seconds (optional, default: 90)
REVIEW_TIMEOUT=

# Override iteration budget (optional, default: 10)
ITERATION_BUDGET=
