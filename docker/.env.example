# ─── GitHub ─────────────────────────────────────────────
GITHUB__USER_TOKEN=

# ─── Webhook ───────────────────────────────────────────
WEBHOOK_SECRET=

# ─── AWS (for future Bedrock integration) ──────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ─── LLM / xAI ────────────────────────────────────────
CONFIG__MODEL=xai/grok-4.3
CONFIG__CUSTOM_MODEL_MAX_TOKENS=131072
CONFIG__FALLBACK_MODELS=["xai/grok-4.3"]
XAI_API_KEY=
OPENAI__KEY=none

# ─── Discord ──────────────────────────────────────────
DISCORD_WEBHOOK_URL=
